#===============================================================================
# go2postgres Environment Configuration
# 
# IMPORTANT: Generate real secrets before production use!
# Run: openssl rand -hex 32
#===============================================================================

#-------------------------------------------------------------------------------
# Security Secrets (MUST BE CHANGED IN PRODUCTION!)
#-------------------------------------------------------------------------------
# 32-byte hex key for encrypting database credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Secret for signing JWT tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your-32-byte-hex-jwt-secret-here

# JWT token expiry (access token refreshes silently, refresh token = session lifetime)
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=168h

#-------------------------------------------------------------------------------
# PostgreSQL Connection
#-------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=your-postgres-password
POSTGRES_BIN_PATH=/usr/lib/postgresql/16/bin
POSTGRES_DATA_DIR=/var/lib/postgresql/16/main

#-------------------------------------------------------------------------------
# HTTP Server
#-------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

#-------------------------------------------------------------------------------
# Application Settings
#-------------------------------------------------------------------------------
SQLITE_DB_PATH=./data/go2postgres.db
LOG_LEVEL=info
LOG_FORMAT=json
ENVIRONMENT=development

#-------------------------------------------------------------------------------
# Feature Flags
#-------------------------------------------------------------------------------
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
SHUTDOWN_TIMEOUT=30s

#-------------------------------------------------------------------------------
# Default Tenant Limits
#-------------------------------------------------------------------------------
DEFAULT_CONN_LIMIT=20
DEFAULT_STATEMENT_TIMEOUT=30s
MAX_INSTANCES_PER_USER=5
MAX_DISK_PER_INSTANCE=10737418240

#-------------------------------------------------------------------------------
# Rate Limiting
#-------------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
REVEAL_PASSWORD_LIMIT=3

#-------------------------------------------------------------------------------
# Admin User
#-------------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ALLOW_REGISTRATION=true

#-------------------------------------------------------------------------------
# Email (Resend)
#-------------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=Your App <noreply@yourdomain.com>
OTP_EXPIRY=10m

#-------------------------------------------------------------------------------
# Frontend
#-------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BASE_DOMAIN=localhost
