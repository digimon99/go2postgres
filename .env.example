# go2postgres Environment Configuration
# Copy this file to .env and fill in the values

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem
BASE_DOMAIN=localhost
SHUTDOWN_TIMEOUT=30s

# SQLite Database (metadata storage)
SQLITE_DB_PATH=./data/go2postgres.db

# PostgreSQL Configuration
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5438
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=your_postgres_superuser_password
POSTGRES_BIN_PATH=/usr/lib/postgresql/16/bin
POSTGRES_DATA_DIR=/var/lib/postgresql/16/main

# Security - CHANGE THESE IN PRODUCTION!
# JWT_SECRET must be at least 32 characters
JWT_SECRET=your_jwt_secret_key_change_this_in_production_32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ENCRYPTION_KEY must be exactly 32 characters for AES-256
ENCRYPTION_KEY=32_character_encryption_key_here

# Password settings
BCRYPT_COST=12
MIN_PASSWORD_LENGTH=12

# Admin user (auto-approved and gets admin role)
ADMIN_EMAIL=admin@example.com

# Registration
ALLOW_REGISTRATION=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
REVEAL_PASSWORD_LIMIT=3

# Instance Defaults
DEFAULT_CONN_LIMIT=20
DEFAULT_STATEMENT_TIMEOUT=30s
MAX_INSTANCES_PER_USER=5
MAX_DISK_PER_INSTANCE=10737418240

# Observability
LOG_LEVEL=info
LOG_FORMAT=json
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30s

# Environment
ENVIRONMENT=development

# Email (Resend API for OTP authentication)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=Your App <noreply@yourdomain.com>
